# copy .env.example .env (Windows)

# Базовый URL API без завершающего слэша (Streamlit подставит путь /predict/).
# Хост и порт должны совпадать с API_HOST и API_PORT в fastapi/.env

API_BASE_URL=http://127.0.0.1:8000
